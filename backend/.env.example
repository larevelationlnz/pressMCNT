# Configuration du serveur
PORT=5000
NODE_ENV=development

# Configuration de la base de données PostgreSQL
# Vous pouvez configurer via une URL de connexion unique :
# DATABASE_URL=postgres://user:password@host:port/database

# Ou via les paramètres de connexion individuels ci-dessous :
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=votre_mot_de_passe_ici
PGDATABASE=presse_mcnt
